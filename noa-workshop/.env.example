# =========================================================================
# NOA Workshop — Environment Variables
# =========================================================================
# Foundry Agent Service 採用「一個 project endpoint + 多個 agent」的設計，
# 而不是「每個 agent 各有 endpoint+key」。請依下面註解填寫。
# 認證使用 Azure CLI (az login)，不需要存 API key。
# =========================================================================

# --- 必填：Foundry Project Endpoint ---
# 在 Microsoft Foundry portal 的 Project 頁面右上角可以看到
# 形式：https://<account>.services.ai.azure.com/api/projects/<project>
FOUNDRY_PROJECT_ENDPOINT=https://<account>.services.ai.azure.com/api/projects/<project>

# --- 必填：模型部署名稱 ---
# 在 Foundry Project > Deployments 中部署的模型名稱（例如 gpt-4o）
# 場景 M1 (本地模式) 會直接用這個 model
# 場景 M3/M4 (hosted 模式) 也會用這個 model 給 Magentic manager
AZURE_AI_MODEL_DEPLOYMENT_NAME=gpt-5.4

# --- 模式切換 ---
# false (預設)：本地模式。Agent 用 FoundryChatClient + 從 markdown 讀 instructions。
#                M1, M2 推薦用這個模式 (學員不需先建 agent)。
# true ：Hosted 模式。Agent 用 FoundryAgent 連到 portal 預先建立的 Prompt Agent。
#         M3, M4 會切換到此模式 (學員會在 Foundry portal 手動建好四個 Prompt Agent)。
NOA_USE_HOSTED_AGENTS=false

# --- Hosted 模式必填：四個 Prompt Agent 的名稱（學員在 Foundry portal 建立後填入） ---
# 命名建議與 instructions 檔名一致，方便對應。
NOA_NOC_MANAGER_AGENT_NAME=noc-manager
NOA_TELEMETRY_AGENT_NAME=telemetry-analyzer
NOA_SECURITY_AGENT_NAME=security-compliance
NOA_FIELD_OPS_AGENT_NAME=field-ops
# NOA_CHANGE_AGENT_NAME=change

# --- Hosted 模式選填：版本（Prompt Agent 才需要；Hosted Agent 留空） ---
NOA_AGENT_VERSION=1.0
